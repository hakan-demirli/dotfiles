#!/usr/bin/env bash
set -euo pipefail

KEY_FILE=""

cleanup() {
  if [[ -n "$KEY_FILE" && -f "$KEY_FILE" ]]; then
    rm -f "$KEY_FILE"
  fi
}
trap cleanup EXIT

decrypt_git_crypt_key() {
  local encrypted_key="$HOME/Desktop/dotfiles/secrets/git-crypt-key"

  if ! head -c8 "$encrypted_key" | grep -q '^Salted__'; then
    echo "File does not appear encrypted." >&2
    exit 1
  fi

  KEY_FILE=$(umask 077 && mktemp /tmp/git-crypt-key.XXXXXXXXXX)

  read -srp "Enter passphrase: " password
  echo

  echo "$password" | openssl enc -d -aes-256-cbc -pbkdf2 \
    -in "$encrypted_key" \
    -out "$KEY_FILE" \
    -pass stdin

  unset password
  echo "Decryption complete."
}

decrypt_secrets() {
  git-crypt unlock "$KEY_FILE"
  ln -sf "$HOME/Desktop/dotfiles/secrets/git_tokens" "$HOME/.config/git/git_tokens"
  ln -sf "$HOME/Desktop/dotfiles/secrets/git_users" "$HOME/.config/git/git_users"
}

disko_format() {
  sudo nix --experimental-features "nix-command flakes" run github:nix-community/disko -- \
    --mode disko /root/dotfiles_tmp/hosts/l01/hardware/disko.nix \
    --arg device '"/dev/vda"'
}

decrypt_git_crypt_key
decrypt_secrets
