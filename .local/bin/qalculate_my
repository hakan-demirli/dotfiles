#!/usr/bin/env bash
set -euo pipefail

is_running=$(pgrep "qalculate" || true)
echo "$is_running"

if [ -n "$is_running" ]; then
  echo "just togglespecialworkspace"
  hyprctl dispatch 'hl.dsp.workspace.toggle_special("calculator")'
else
  echo "just qalculate"
  qalculate-qt &
  # hyprctl dispatch focuswindow title:my_player
fi
