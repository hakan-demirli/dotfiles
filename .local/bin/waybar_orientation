#!/usr/bin/env bash

state_dir="${XDG_RUNTIME_DIR:-/run/user/$UID}"
tablet="$(cat "$state_dir/tablet_mode" 2> /dev/null)"

if [[ $(hostname 2> /dev/null) != "l02" || $tablet != "on" ]]; then
  printf '{"text":"","tooltip":"","class":"orient-hidden","alt":"hidden"}\n'
  exit 0
fi

locked="$(cat "$state_dir/orientation_lock" 2> /dev/null)"

if [[ $locked == "1" ]]; then
  printf '{"text":"\uf023","tooltip":"Rotation locked (click to auto-rotate)","class":"orient-lock","alt":"lock"}\n'
else
  printf '{"text":"\uf021","tooltip":"Auto-rotate (click to lock)","class":"orient-auto","alt":"auto"}\n'
fi
