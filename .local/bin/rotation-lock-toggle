#!/usr/bin/env bash

set -euo pipefail

STATE_DIR="${XDG_RUNTIME_DIR:-/run/user/$UID}"
LOCK_FILE="$STATE_DIR/orientation_lock"
WATCHER_PATTERN="orientation_watcher"

notify() {
  command -v notify-send >/dev/null 2>&1 || return 0
  notify-send -a rotation-lock -t 2000 \
    -h string:x-canonical-private-synchronous:rotation-lock \
    "$1" "${2:-}" 2>/dev/null || true
}

signal_waybar() {
  pkill -RTMIN+6 waybar 2>/dev/null || true
}

watcher_running() {
  pgrep -f "$WATCHER_PATTERN" >/dev/null 2>&1
}

read_state() {
  local v
  v="$(cat "$LOCK_FILE" 2>/dev/null || true)"
  [[ "$v" == "1" ]] && printf 'on\n' || printf 'off\n'
}

write_state() {
  mkdir -p "$STATE_DIR"
  printf '%s' "$1" >"$LOCK_FILE"
}

set_locked() {
  case "$1" in
  on) write_state 1 ;;
  off) write_state 0 ;;
  *) return 2 ;;
  esac
  signal_waybar
}

lock_on() {
  if [[ "$(read_state)" == "on" ]]; then
    return 0
  fi
  set_locked on
  notify "Rotation locked" "Screen will not auto-rotate"
}

lock_off() {
  if [[ "$(read_state)" == "off" ]]; then
    return 0
  fi
  if watcher_running; then
    pkill -USR1 -f "$WATCHER_PATTERN" 2>/dev/null || true
  else
    set_locked off
  fi
  notify "Rotation unlocked" "Auto-rotate restored"
}

toggle() {
  if [[ "$(read_state)" == "on" ]]; then
    lock_off
  else
    lock_on
  fi
}

status() {
  if [[ "$(read_state)" == "on" ]]; then
    printf 'true\n'
  else
    printf 'false\n'
  fi
}

from_toggle_state() {
  case "${SWAYNC_TOGGLE_STATE:-}" in
  true | TRUE | 1) lock_on ;;
  false | FALSE | 0) lock_off ;;
  *)
    printf 'SWAYNC_TOGGLE_STATE must be true or false, got [%s]\n' \
      "${SWAYNC_TOGGLE_STATE:-}" >&2
    return 2
    ;;
  esac
}

case "${1:-toggle}" in
true | TRUE | 1) lock_on ;;
false | FALSE | 0) lock_off ;;
swaync) from_toggle_state ;;
on | lock) lock_on ;;
off | unlock) lock_off ;;
status) status ;;
toggle) toggle ;;
*)
  printf 'Usage: %s [toggle|on|off|status|swaync|true|false]\n' "$0" >&2
  exit 2
  ;;
esac
