#!/usr/bin/env python3
"""
git_cached: transparent local cache for `git clone`.

Strategy: maintain a bare --mirror per remote URL under ~/.cache/git_cache.
For `git clone`, pass --reference-if-able <mirror> --dissociate so git itself
reuses local objects. All other git subcommands are exec'd through unchanged.

User-visible behavior of `git` is unchanged. Set GIT_CACHE_DISABLE=1 to bypass.
"""

from __future__ import annotations

import fcntl
import hashlib
import logging
import os
import re
import shutil
import subprocess
import sys
import time
from typing import Optional, Tuple
from urllib.parse import urlparse

GIT = "git"
DEFAULT_TTL_SECONDS = 300


def cache_root() -> str:
    xdg = os.environ.get("XDG_CACHE_HOME", os.path.expanduser("~/.cache"))
    root = os.path.join(xdg, "git_cache")
    os.makedirs(root, exist_ok=True)
    os.makedirs(os.path.join(root, "locks"), exist_ok=True)
    return root


def setup_logger() -> None:
    log_file = os.path.join(cache_root(), "git_cache.log")
    logging.basicConfig(
        filename=log_file,
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(message)s",
    )


_SCP_RE = re.compile(r"^(?P<user>[^@/:]+@)?(?P<host>[^:/]+):(?P<path>[^/].*)$")


def normalize_url(url: str) -> Optional[Tuple[str, str]]:
    """
    Return (canonical_url_for_clone, cache_key_path) or None if not cacheable.

    cache_key_path is a relative path like 'github.com/user/repo' used to
    locate the bare mirror on disk. Local paths and file:// are not cached.
    """
    if not url:
        return None

    if (
        url.startswith("file://")
        or url.startswith("/")
        or url.startswith("./")
        or url.startswith("../")
    ):
        return None

    host = None
    path = None

    m = _SCP_RE.match(url)
    if m and "://" not in url:
        host = m.group("host")
        path = m.group("path")
    else:
        parsed = urlparse(url)
        if parsed.scheme not in ("http", "https", "ssh", "git"):
            return None
        host = parsed.hostname
        path = parsed.path.lstrip("/")

    if not host or not path:
        return None

    key_path = path
    if key_path.endswith(".git"):
        key_path = key_path[:-4]
    key_path = key_path.rstrip("/")
    if not key_path or "/" not in key_path:
        return None

    host_l = host.lower()

    parts = [p for p in key_path.split("/") if p and p != "."]
    if any(p == ".." for p in parts):
        return None

    cache_key = os.path.join(host_l, *parts)
    return url, cache_key


def mirror_path(cache_key: str) -> str:
    return os.path.join(cache_root(), cache_key + ".git")


def lock_path(cache_key: str) -> str:
    h = hashlib.sha1(cache_key.encode()).hexdigest()
    return os.path.join(cache_root(), "locks", h + ".lock")


def run_git_capture(args, cwd=None) -> Tuple[int, str, str]:
    p = subprocess.run([GIT, *args], cwd=cwd, capture_output=True, text=True)
    return p.returncode, p.stdout, p.stderr


def exec_git_passthrough(args) -> int:
    """Run git inheriting stdio so the user sees progress, return exit code."""
    try:
        return subprocess.call([GIT, *args])
    except FileNotFoundError:
        sys.stderr.write("git_cached: 'git' not found on PATH\n")
        return 127


class _FileLock:
    def __init__(self, path: str):
        self.path = path
        self._fd: Optional[int] = None

    def __enter__(self):
        self._fd = os.open(self.path, os.O_CREAT | os.O_RDWR, 0o644)
        fcntl.flock(self._fd, fcntl.LOCK_EX)
        return self

    def __exit__(self, exc_type, exc, tb):
        try:
            fcntl.flock(self._fd, fcntl.LOCK_UN)
        finally:
            os.close(self._fd)
            self._fd = None


def _mirror_is_valid(path: str) -> bool:
    if not os.path.isdir(path):
        return False

    return os.path.isfile(os.path.join(path, "HEAD")) and os.path.isdir(
        os.path.join(path, "objects")
    )


def _mirror_age_seconds(path: str) -> float:
    candidates = [
        os.path.join(path, "FETCH_HEAD"),
        os.path.join(path, "packed-refs"),
        os.path.join(path, "HEAD"),
    ]
    newest = 0.0
    for c in candidates:
        try:
            newest = max(newest, os.path.getmtime(c))
        except OSError:
            pass
    if newest == 0.0:
        return float("inf")
    return time.time() - newest


def _invalidate_mirror_locked(mpath: str, cache_key: str, reason: str) -> None:
    """Remove a mirror directory. Caller must already hold the cache_key lock."""
    if os.path.exists(mpath):
        shutil.rmtree(mpath, ignore_errors=True)
        logging.info("invalidated mirror (%s): %s", reason, cache_key)


def invalidate_mirror(cache_key: str, reason: str = "external") -> None:
    """Remove a mirror directory, taking the cache_key lock."""
    mpath = mirror_path(cache_key)
    try:
        with _FileLock(lock_path(cache_key)):
            _invalidate_mirror_locked(mpath, cache_key, reason)
    except OSError as e:
        logging.warning("could not invalidate mirror %s: %s", cache_key, e)


def ensure_mirror(url: str, cache_key: str, ttl: int) -> Optional[str]:
    """
    Ensure a bare mirror exists and is reasonably fresh. Returns the mirror
    path on success, or None if we should fall back to a plain clone.
    """
    mpath = mirror_path(cache_key)
    os.makedirs(os.path.dirname(mpath), exist_ok=True)

    with _FileLock(lock_path(cache_key)):
        if _mirror_is_valid(mpath):
            age = _mirror_age_seconds(mpath)
            if age < ttl:
                logging.info("mirror fresh (%.0fs) %s", age, cache_key)
                return mpath
            logging.info("mirror stale (%.0fs) updating %s", age, cache_key)
            rc, _, err = run_git_capture(["-C", mpath, "remote", "update", "--prune"])
            if rc != 0:
                logging.warning(
                    "mirror update failed (%d) for %s: %s; rebuilding",
                    rc,
                    cache_key,
                    err.strip().splitlines()[-1:] or "",
                )
                _invalidate_mirror_locked(mpath, cache_key, "update_failed")
            else:
                try:
                    fh = os.path.join(mpath, "FETCH_HEAD")
                    open(fh, "a").close()
                    os.utime(fh, None)
                except OSError:
                    pass
                return mpath

        if os.path.exists(mpath):
            logging.warning("removing invalid mirror dir %s", mpath)
            shutil.rmtree(mpath, ignore_errors=True)

        logging.info("creating mirror %s", cache_key)

        rc, _, err = run_git_capture(["clone", "--mirror", "--quiet", url, mpath])
        if rc != 0:
            logging.warning(
                "mirror creation failed (%d) for %s: %s",
                rc,
                cache_key,
                err.strip(),
            )
            shutil.rmtree(mpath, ignore_errors=True)
            return None
        return mpath


_CLONE_VALUE_FLAGS = {
    "-o",
    "--origin",
    "-b",
    "--branch",
    "-u",
    "--upload-pack",
    "--reference",
    "--reference-if-able",
    "--separate-git-dir",
    "--depth",
    "--shallow-since",
    "--shallow-exclude",
    "--template",
    "--server-option",
    "--filter",
    "--bundle-uri",
    "-c",
    "--config",
    "-j",
    "--jobs",
}


def _clone_positionals(clone_args) -> list:
    i = 0
    positionals: list = []
    while i < len(clone_args):
        a = clone_args[i]
        if a == "--":
            positionals.extend(clone_args[i + 1 :])
            break
        if a.startswith("--") and "=" in a:
            i += 1
            continue
        if a in _CLONE_VALUE_FLAGS:
            i += 2
            continue
        if a.startswith("-"):
            i += 1
            continue
        positionals.append(a)
        i += 1
    return positionals


def find_clone_url(clone_args) -> Optional[str]:
    """Best-effort: find the first positional argument (the source repo)."""
    p = _clone_positionals(clone_args)
    return p[0] if p else None


def find_clone_dest(clone_args, url: str) -> Optional[str]:
    """
    Best-effort: figure out the destination directory git clone will create.
    Used so we can clean up after a failed cached clone attempt before retrying.
    """
    positionals = _clone_positionals(clone_args)
    if len(positionals) >= 2:
        return positionals[1]

    name = url.rstrip("/").rsplit("/", 1)[-1]
    if name.endswith(".git"):
        name = name[:-4]
    if not name:
        return None
    if "--bare" in clone_args or "--mirror" in clone_args:
        name = name + ".git"
    return name


def _cleanup_failed_clone(dest: Optional[str], dest_existed_before: bool) -> None:
    """Remove what we created during a failed cached clone attempt."""
    if not dest:
        return
    try:
        abs_dest = os.path.abspath(dest)
    except OSError:
        return
    if not os.path.lexists(abs_dest):
        return
    if not dest_existed_before:
        shutil.rmtree(abs_dest, ignore_errors=True)
        logging.info("removed failed clone destination: %s", abs_dest)
        return

    git_dir = os.path.join(abs_dest, ".git")
    if os.path.isdir(git_dir):
        shutil.rmtree(git_dir, ignore_errors=True)
        logging.info("removed .git from pre-existing dest: %s", abs_dest)


def _try_cached_clone(cached_args) -> int:
    """
    Run the cached clone with output captured so a failure can be silently
    recovered. On success the captured streams are replayed to the user so
    the experience is indistinguishable from a normal clone.
    """
    try:
        p = subprocess.run([GIT, *cached_args], capture_output=True, text=True)
    except FileNotFoundError:
        sys.stderr.write("git_cached: 'git' not found on PATH\n")
        return 127

    if p.returncode == 0:
        if p.stdout:
            sys.stdout.write(p.stdout)
            sys.stdout.flush()
        if p.stderr:
            sys.stderr.write(p.stderr)
            sys.stderr.flush()
        return 0

    tail = " | ".join(line for line in p.stderr.strip().splitlines()[-6:])
    logging.warning(
        "cached clone failed (rc=%d) stderr-tail: %s", p.returncode, tail[:2000]
    )
    return p.returncode


def handle_clone(args) -> int:
    """args is the full argv after the leading 'clone'."""
    if os.environ.get("GIT_CACHE_DISABLE") == "1":
        return exec_git_passthrough(["clone", *args])

    url = find_clone_url(args)
    if not url:
        return exec_git_passthrough(["clone", *args])

    norm = normalize_url(url)
    if norm is None:
        logging.info("uncacheable url, passthrough: %s", url)
        return exec_git_passthrough(["clone", *args])

    canonical_url, cache_key = norm
    ttl = int(os.environ.get("GIT_CACHE_TTL", DEFAULT_TTL_SECONDS))

    dest = find_clone_dest(args, canonical_url)
    dest_existed_before = bool(dest) and os.path.lexists(dest)

    mpath = ensure_mirror(canonical_url, cache_key, ttl)
    if mpath is None:
        logging.info("no mirror, plain clone: %s", cache_key)
        return exec_git_passthrough(["clone", *args])

    cached_args = ["clone", "--reference-if-able", mpath, "--dissociate", *args]
    logging.info("cached clone: %s", cache_key)

    rc = _try_cached_clone(cached_args)
    if rc == 0:
        return 0

    logging.warning(
        "cached clone failed (rc=%d); invalidating mirror and retrying plain: %s",
        rc,
        cache_key,
    )
    invalidate_mirror(cache_key, reason="clone_failed")
    _cleanup_failed_clone(dest, dest_existed_before)

    return exec_git_passthrough(["clone", *args])


def main() -> int:
    setup_logger()
    argv = sys.argv[1:]
    if argv and argv[0] == "clone":
        return handle_clone(argv[1:])
    return exec_git_passthrough(argv)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
