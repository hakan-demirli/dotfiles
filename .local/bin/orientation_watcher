#!/usr/bin/env python3
import contextlib
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import time

STATE_DIR = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
ORIENT_STATE_FILE = os.path.join(STATE_DIR, "orientation")
LOCK_STATE_FILE = os.path.join(STATE_DIR, "orientation_lock")

DEBOUNCE_S = 0.3
RESPAWN_S = 2.0

_ORIENT_TO_TRANSFORM = {
    "normal": 0,
    "left-up": 1,
    "bottom-up": 2,
    "right-up": 3,
}

_RE_INIT = re.compile(r"Has accelerometer \(orientation:\s*([a-z-]+)")
_RE_CHANGE = re.compile(r"orientation changed:\s*([a-z-]+)")

_current_transform = -1
_current_orientation = "undefined"
_last_apply_t = 0.0


def log(msg: str) -> None:
    sys.stderr.write(f"[orientation_watcher] {time.strftime('%H:%M:%S')} {msg}\n")
    sys.stderr.flush()


def is_locked() -> bool:
    try:
        with open(LOCK_STATE_FILE) as f:
            return f.read().strip() == "1"
    except OSError:
        return False


def write_text(path: str, content: str) -> None:
    try:
        with open(path, "w") as f:
            f.write(content)
    except OSError as e:
        log(f"write {path}: {e}")


def signal_waybar() -> None:
    with contextlib.suppress(Exception):
        subprocess.run(["pkill", "-RTMIN+6", "waybar"], check=False, timeout=2)


def hyprctl_json(*args: str) -> object | None:
    try:
        out = subprocess.run(
            ["hyprctl", "-j", *args],
            check=False,
            timeout=5,
            capture_output=True,
            text=True,
        ).stdout
        return json.loads(out)
    except Exception as e:
        log(f"hyprctl -j {' '.join(args)}: {e}")
        return None


def select_touch_monitor() -> tuple[str, str] | None:
    monitors = hyprctl_json("monitors")
    if not isinstance(monitors, list) or not monitors:
        log("hyprctl monitors returned no monitors")
        return None

    target = os.environ.get("ORIENTATION_MONITOR", "eDP-1")
    if target:
        for m in monitors:
            if m.get("name") == target:
                return m["name"], m.get("description", "")
        log(f"touch monitor {target} not found; falling back to focused")

    for m in monitors:
        if m.get("focused"):
            return m["name"], m.get("description", "")

    first = monitors[0]
    return first["name"], first.get("description", "")


def _hyprctl_eval(lua: str) -> bool:
    try:
        r = subprocess.run(
            ["hyprctl", "eval", lua],
            check=False,
            timeout=5,
            capture_output=True,
            text=True,
        )
        out = (r.stdout or "").strip()
        if r.returncode != 0 or out.lower().startswith("error"):
            log(f"hyprctl eval failed (rc={r.returncode}): {out or r.stderr.strip()} | {lua}")
            return False
        return True
    except Exception as e:
        log(f"hyprctl eval {lua}: {e}")
        return False


def _monitor_spec(mon_name: str) -> dict | None:
    monitors = hyprctl_json("monitors")
    if not isinstance(monitors, list):
        return None
    m = next((x for x in monitors if x.get("name") == mon_name), None)
    if not m:
        return None
    w, h, rr, scale = m.get("width"), m.get("height"), m.get("refreshRate"), m.get("scale")
    if not (w and h and rr and scale):
        return None
    return {
        "name": mon_name,
        "mode": f"{w}x{h}@{rr}",
        "position": f"{m.get('x', 0)}x{m.get('y', 0)}",
        "scale": scale,
    }


def apply_hyprctl_keywords(transform: int, mon_name: str, mon_desc: str) -> bool:
    base = _monitor_spec(mon_name)
    if base:
        mon_lua = (
            'hl.monitor({ output = "%s", mode = "%s", position = "%s", scale = %s, transform = %d })'
            % (base["name"], base["mode"], base["position"], base["scale"], transform)
        )
    else:
        log("no monitor baseline; transform-only (scale may reset)")
        mon_lua = 'hl.monitor({ output = "%s", transform = %d })' % (mon_name, transform)
    input_lua = (
        "hl.config({ input = { touchdevice = { transform = %d }, "
        "tablet = { transform = %d } } })" % (transform, transform)
    )
    ok = _hyprctl_eval(mon_lua)
    ok = _hyprctl_eval(input_lua) and ok
    return ok


def apply_transform(transform: int, *, force: bool = False) -> None:
    global _current_transform, _last_apply_t

    if not force and transform == _current_transform:
        return

    now = time.monotonic()
    if not force and (now - _last_apply_t) < DEBOUNCE_S:
        return

    selected = select_touch_monitor()
    if selected is None:
        log("no monitor selected; skipping rotation")
        return
    mon_name, mon_desc = selected

    if not apply_hyprctl_keywords(transform, mon_name, mon_desc):
        log(f"apply_hyprctl_keywords failed for transform={transform}")
        return

    _current_transform = transform
    _last_apply_t = now
    write_text(ORIENT_STATE_FILE, str(transform))
    signal_waybar()
    log(f"transform -> {transform} (monitor={mon_name})")


def maybe_apply_orientation(orient: str) -> None:
    global _current_orientation
    transform = _ORIENT_TO_TRANSFORM.get(orient)
    if transform is None:
        return
    _current_orientation = orient
    if is_locked():
        return
    apply_transform(transform)


def on_sigusr1(_signum, _frame):
    new_locked = not is_locked()
    write_text(LOCK_STATE_FILE, "1" if new_locked else "0")
    log(f"rotation lock -> {'on' if new_locked else 'off'}")
    signal_waybar()
    if not new_locked and _current_orientation in _ORIENT_TO_TRANSFORM:
        apply_transform(_ORIENT_TO_TRANSFORM[_current_orientation])


def on_exit(_signum, _frame):
    log("exit: reset transform")
    apply_transform(0, force=True)
    sys.exit(0)


def sensor_command() -> list[str] | None:
    mon = shutil.which("monitor-sensor")
    if not mon:
        return None
    stdbuf = shutil.which("stdbuf")
    return [stdbuf, "-oL", mon] if stdbuf else [mon]


def run() -> int:
    signal.signal(signal.SIGUSR1, on_sigusr1)
    signal.signal(signal.SIGTERM, on_exit)
    signal.signal(signal.SIGINT, on_exit)

    cmd = sensor_command()
    if cmd is None:
        log("monitor-sensor not found (need iio-sensor-proxy); aborting")
        return 1

    if not os.path.exists(LOCK_STATE_FILE):
        write_text(LOCK_STATE_FILE, "0")
    log(f"initial rotation lock = {'on' if is_locked() else 'off'}")
    signal_waybar()

    while True:
        log(f"starting sensor source: {' '.join(cmd)}")
        try:
            proc = subprocess.Popen(
                cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True
            )
        except Exception as e:
            log(f"failed to start monitor-sensor: {e}")
            time.sleep(RESPAWN_S)
            continue

        assert proc.stdout is not None
        for line in proc.stdout:
            m = _RE_CHANGE.search(line) or _RE_INIT.search(line)
            if m:
                maybe_apply_orientation(m.group(1))

        rc = proc.wait()
        log(f"monitor-sensor exited (rc={rc}); respawning in {RESPAWN_S:.0f}s")
        time.sleep(RESPAWN_S)


if __name__ == "__main__":
    sys.exit(run())
