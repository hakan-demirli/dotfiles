#!/usr/bin/env bash
# Manual power control for HP OmniBook Ultra Flip 14 (board 8CDE, Core Ultra 7 258V).
# Writes RAPL PL1/PL2, governor, EPP, platform_profile, EC AFAN (0x2D), HWP_REQUEST (MSR 0x774).
#
# AFAN (EC offset 0x2D) selects the EC's autonomous fan profile. Values from
# DSDT \_SB.PC00.UFID, verified by brute-force probing (see hp-afan-probe).
#   - EC only accepts low nibble 0-9; values with low nibble A-F are rejected
#     (rounded up to next x0).
#   - 0x00 = max cooling (~3400/4000 RPM steady).  Not "passive".
#   - 0x88 = most passive DSDT value.  Both fans reach 964 RPM (tach 0xFF,
#     effectively off) when CPU ≤35C.  CPU fan stays ~2961 RPM above ~37C.
#   - Values above 0x88 (0x90, 0x99, ...) wrap/alias to aggressive modes;
#     they do NOT become more passive.
#   - 0x08, 0x18, 0x28 also reach both-fans-off but are non-DSDT values.
#   - 0x33 briefly shows both-min then GPU fan spins back up (transient only).
#   - The EC continuously overwrites FTGC/FT2C (fan target registers); writing
#     them from userspace has no lasting effect.
#
# HWP allowlist from HWP_CAPABILITIES (MSR 0x771).
set -u
set -o pipefail

RAPL=/sys/class/powercap/intel-rapl:0
MMIO=/sys/class/powercap/intel-rapl-mmio:0
PLATFORM_PROFILE=/sys/firmware/acpi/platform_profile
EC_IO=/sys/kernel/debug/ec/ec0/io
EC_AFAN_OFFSET=45 # 0x2D
# DSDT-approved values (UFID method) plus 08/18/28 which also achieve both-fans-off.
# EC rejects low nibble >= 0xA.  See header comment for full probing results.
EC_AFAN_VALID="00 08 11 18 22 28 33 44 55 66 77 88"
MSR_HWP_REQUEST=0x774
MSR_HWP_CAPS=0x771
HWP_MAX_VALID="01 13 1a 26 30 37"

ORIG_ARGS=("$@")

need_root() {
  [ "$(id -u)" -eq 0 ] || exec sudo -E "$0" "${ORIG_ARGS[@]}"
}

write_to() {
  local path=$1 val=$2 actual
  [ -e "$path" ] || {
    echo "  skip $path"
    return 0
  }
  if printf '%s\n' "$val" > "$path" 2> /dev/null; then
    actual=$(cat "$path" 2> /dev/null)
    [ "$actual" = "$val" ] && echo "  ok   $path = $val" || echo "  FAIL $path: wrote '$val' reads '$actual'"
  else
    echo "  FAIL $path: write rejected"
  fi
}

set_rapl() {
  local pl1=$(($1 * 1000000)) pl2=$(($2 * 1000000))
  echo "RAPL PL1=${1}W PL2=${2}W:"
  write_to "$RAPL/constraint_0_power_limit_uw" "$pl1"
  write_to "$RAPL/constraint_1_power_limit_uw" "$pl2"
  write_to "$MMIO/constraint_0_power_limit_uw" "$pl1"
  write_to "$MMIO/constraint_1_power_limit_uw" "$pl2"
}

set_governor() {
  local gov=$1 fail=0 n=0
  for p in /sys/devices/system/cpu/cpufreq/policy*/scaling_governor; do
    n=$((n + 1))
    printf '%s\n' "$gov" > "$p" 2> /dev/null || fail=$((fail + 1))
  done
  echo "governor=$gov ($n): $([ "$fail" -eq 0 ] && echo ok || echo "FAIL on $fail")"
}

# governor=performance pins EPP and rejects further writes; skip to avoid spurious FAIL.
set_epp() {
  local epp=$1 gov fail=0 n=0
  gov=$(cat /sys/devices/system/cpu/cpufreq/policy0/scaling_governor 2> /dev/null)
  if [ "$gov" = "performance" ]; then
    echo "EPP=performance (pinned by governor)"
    return 0
  fi
  for p in /sys/devices/system/cpu/cpufreq/policy*/energy_performance_preference; do
    n=$((n + 1))
    printf '%s\n' "$epp" > "$p" 2> /dev/null || fail=$((fail + 1))
  done
  echo "EPP=$epp ($n): $([ "$fail" -eq 0 ] && echo ok || echo "FAIL on $fail")"
}

set_platform_profile() {
  local profile=$1
  echo "platform_profile=$profile:"
  [ -e "$PLATFORM_PROFILE" ] || {
    echo "  skip $PLATFORM_PROFILE"
    return 0
  }
  printf '%s\n' "$profile" > "$PLATFORM_PROFILE" 2> /dev/null \
    && echo "  ok   <- $profile" \
    || echo "  FAIL write rejected"
}

ensure_ec_sys() {
  [ -e "$EC_IO" ] || modprobe ec_sys write_support=1 2> /dev/null || true
  [ -w "$EC_IO" ] || {
    echo "  FAIL $EC_IO not writable (need ec_sys.write_support=1)" >&2
    return 1
  }
}

read_afan() {
  [ -r "$EC_IO" ] || {
    echo "?"
    return
  }
  dd if="$EC_IO" bs=1 count=1 skip="$EC_AFAN_OFFSET" 2> /dev/null | od -An -tx1 | tr -d ' \n'
}

# Writes EC byte 0x2D. Aborts on tampered offset, bad hex, value not in allowlist,
# or unreadable EC. dd bs=1 count=1 bounds damage to 1 byte at offset 0x2D.
set_afan() {
  local hex=${1:-} ok=0 v before
  [ "${EC_AFAN_OFFSET:-}" = "45" ] || {
    echo "  ABORT EC_AFAN_OFFSET tampered" >&2
    return 99
  }
  [[ $hex =~ ^[0-9a-f]{2}$ ]] || {
    echo "  ABORT bad AFAN '$hex' (need 2 lowercase hex chars)" >&2
    return 99
  }
  if [ "${HP_POWER_AFAN_ALLOW_ANY:-0}" != "1" ]; then
    for v in $EC_AFAN_VALID; do [ "$hex" = "$v" ] && ok=1 && break; done
    [ "$ok" -eq 1 ] || {
      echo "  ABORT '0x$hex' not in allowlist ($EC_AFAN_VALID); override with HP_POWER_AFAN_ALLOW_ANY=1" >&2
      return 99
    }
  fi
  echo "EC AFAN (0x2D) <- 0x$hex:"
  ensure_ec_sys || return 1
  before=$(read_afan)
  [[ $before =~ ^[0-9a-f]{2}$ ]] || {
    echo "  ABORT can't read current AFAN ('$before')" >&2
    return 99
  }
  printf '%b' "\\x$hex" \
    | dd of="$EC_IO" bs=1 count=1 seek="$EC_AFAN_OFFSET" conv=notrunc status=none 2> /dev/null \
    || {
      echo "  FAIL write"
      return 1
    }
  local actual=$(read_afan)
  [ "$actual" = "$hex" ] && echo "  ok   AFAN = 0x$hex (was 0x$before)" \
    || {
      echo "  FAIL wrote 0x$hex reads 0x$actual (was 0x$before)"
      return 1
    }
}

ensure_msr() {
  [ -e /dev/cpu/0/msr ] || modprobe msr 2> /dev/null || true
  [ -w /dev/cpu/0/msr ] || {
    echo "  FAIL /dev/cpu/0/msr not writable" >&2
    return 1
  }
  command -v wrmsr > /dev/null && command -v rdmsr > /dev/null \
    || {
      echo "  FAIL wrmsr/rdmsr missing (need msr-tools)" >&2
      return 1
    }
}

read_hwp_request() {
  command -v rdmsr > /dev/null && [ -r /dev/cpu/0/msr ] || {
    echo "?"
    return
  }
  rdmsr -p 0 "$MSR_HWP_REQUEST" 2> /dev/null || echo "?"
}

# Writes MSR 0x774 on every CPU. Forces min=0x01 EPP=0x00 act=0x00, max=<arg>.
set_hwp() {
  local max=${1:-} ok=0 v before after n=0 fail=0 c
  [ "${MSR_HWP_REQUEST:-}" = "0x774" ] || {
    echo "  ABORT MSR_HWP_REQUEST tampered" >&2
    return 99
  }
  [[ $max =~ ^[0-9a-f]{2}$ ]] || {
    echo "  ABORT bad HWP max '$max'" >&2
    return 99
  }
  if [ "${HP_POWER_HWP_ALLOW_ANY:-0}" != "1" ]; then
    for v in $HWP_MAX_VALID; do [ "$max" = "$v" ] && ok=1 && break; done
    [ "$ok" -eq 1 ] || {
      echo "  ABORT '0x$max' not in allowlist ($HWP_MAX_VALID); override with HP_POWER_HWP_ALLOW_ANY=1" >&2
      return 99
    }
  fi
  local val="0x00${max}01"
  echo "HWP_REQUEST <- $val (min=01 max=$max EPP=00):"
  ensure_msr || return 1
  before=$(read_hwp_request)
  for c in /dev/cpu/[0-9]*/msr; do
    n=$((n + 1))
    wrmsr -p "$(basename "$(dirname "$c")")" "$MSR_HWP_REQUEST" "$val" 2> /dev/null \
      || fail=$((fail + 1))
  done
  after=$(read_hwp_request)
  [ "$fail" -eq 0 ] && echo "  ok   $n CPUs, cpu0: 0x$before -> 0x$after" \
    || {
      echo "  FAIL $fail/$n CPUs rejected (cpu0 0x$before -> 0x$after)"
      return 1
    }
}

read_w() { awk '{printf "%d", $1/1000000}' "$1" 2> /dev/null || echo "?"; }

cmd_status() {
  local ac hwp lo hmin hmax hepp mhz pp peak gt
  ac=$(cat /sys/class/power_supply/AC*/online 2> /dev/null | head -1)
  : "${ac:=?}"
  pp=$(cat "$PLATFORM_PROFILE" 2> /dev/null) || pp="(readback broken)"
  echo "AC online            : $ac"
  echo "RAPL PL1 / PL2 (W)   : $(read_w $RAPL/constraint_0_power_limit_uw) / $(read_w $RAPL/constraint_1_power_limit_uw)"
  if [ -d "$MMIO" ]; then
    peak="?"
    [ -e "$MMIO/constraint_2_power_limit_uw" ] && peak=$(read_w "$MMIO/constraint_2_power_limit_uw")
    echo "MMIO PL1 / PL2 / Peak: $(read_w $MMIO/constraint_0_power_limit_uw) / $(read_w $MMIO/constraint_1_power_limit_uw) / $peak"
  fi
  echo "Governor (cpu0)      : $(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2> /dev/null)"
  echo "EPP (cpu0)           : $(cat /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference 2> /dev/null)"
  echo "Platform profile     : $pp"
  echo "EC AFAN (0x2D)       : 0x$(read_afan)"
  hwp=$(read_hwp_request)
  if [ "$hwp" != "?" ] && [ -n "$hwp" ]; then
    lo=$(printf '%08x' "0x$hwp" 2> /dev/null || echo "????????")
    hmin=${lo: -2}
    hmax=${lo: -4:2}
    hepp=${lo: -6:2}
    mhz=$((16#$hmax * 100))
    echo "HWP_REQUEST (0x774)  : min=0x$hmin max=0x$hmax (${mhz}MHz) EPP=0x$hepp"
  else
    echo "HWP_REQUEST (0x774)  : (rdmsr unavailable)"
  fi
  gt=/sys/class/drm/card0/device/tile0/gt0/freq0
  if [ -d "$gt" ]; then
    echo "GT0 max / cur (MHz)  : $(cat $gt/max_freq 2> /dev/null) / $(cat $gt/cur_freq 2> /dev/null)"
    echo "GT0 throttle reasons : $(cat $gt/throttle/reasons 2> /dev/null)"
  fi
}

apply() {
  local mode=$1 pl1=$2 pl2=$3 gov=$4 epp=$5 profile=$6 afan=$7 hwp_max=$8
  echo "==> $mode: PL=${pl1}/${pl2}W gov=$gov EPP=$epp profile=$profile AFAN=0x$afan HWP=0x$hwp_max"
  set_rapl "$pl1" "$pl2"
  set_governor "$gov"
  set_epp "$epp"
  set_platform_profile "$profile"
  set_afan "$afan"
  set_hwp "$hwp_max"
  echo
  cmd_status
}

cmd_turbo() {
  need_root
  # AFAN=0x00: max cooling, both fans ~3400/4000 RPM steady-state.
  apply turbo 37 95 performance performance performance 00 37
}
cmd_balanced() {
  need_root
  apply balanced 28 55 performance performance balanced 44 1a
}
cmd_silent() {
  need_root
  # AFAN=0x88: most passive DSDT profile.  At PL1=15W the CPU stays ≤35C and
  # both fans reach tach 0xFF (~964 RPM, effectively off).  If CPU exceeds ~37C
  # the EC spins the CPU fan back to ~2961 RPM.
  apply silent 15 25 powersave power cool 88 13
}

parse_hex2() {
  local hex=${1:-}
  hex=${hex#0x}
  hex=${hex#0X}
  [[ $hex =~ ^[0-9a-fA-F]{1,2}$ ]] || {
    echo "bad hex: $1" >&2
    return 2
  }
  [ ${#hex} -eq 1 ] && hex="0$hex"
  printf '%s' "$hex" | tr 'A-F' 'a-f'
}

cmd_afan() {
  need_root
  if [ -z "${1:-}" ]; then
    echo "EC AFAN (0x2D) = 0x$(read_afan)"
    echo "valid: $EC_AFAN_VALID  (0x00=max fans, 0x88=most passive, see hp-power help)"
    return 0
  fi
  local hex
  hex=$(parse_hex2 "$1") || return $?
  set_afan "$hex"
}

cmd_hwp() {
  need_root
  if [ -z "${1:-}" ]; then
    local val=$(read_hwp_request) caps lo
    echo "HWP_REQUEST (0x774, cpu0) = 0x$val"
    if [ "$val" != "?" ] && [ -n "$val" ]; then
      lo=$(printf '%08x' "0x$val" 2> /dev/null)
      echo "  min=0x${lo: -2} max=0x${lo: -4:2} (~$((16#${lo: -4:2} * 100))MHz) EPP=0x${lo: -6:2}"
    fi
    if command -v rdmsr > /dev/null && [ -r /dev/cpu/0/msr ]; then
      caps=$(rdmsr -p 0 "$MSR_HWP_CAPS" 2> /dev/null)
      [ -n "$caps" ] && echo "HWP_CAPABILITIES (0x771) = 0x$caps"
    fi
    echo "valid max: $HWP_MAX_VALID  (01=~100M  13=~1.9G  1a=~2.6G  26=~3.8G  30=~4.8G  37=~5.5G)"
    return 0
  fi
  local hex
  hex=$(parse_hex2 "$1") || return $?
  set_hwp "$hex"
}

# --- Fan probing helpers ---------------------------------------------------

EC_FRDC_OFF=46  # 0x2E  CPU fan tach
EC_FTGC_OFF=47  # 0x2F  CPU fan target (EC-set)
EC_FR2C_OFF=53  # 0x35  GPU fan tach
EC_FT2C_OFF=54  # 0x36  GPU fan target (EC-set)
EC_CRZN_OFF=34  # 0x22  cooling zone selector
EC_TEMP_OFF=38  # 0x26  temp for selected zone

read_ec_byte() {
  dd if="$EC_IO" bs=1 count=1 skip="$1" 2> /dev/null | od -An -tx1 | tr -d ' \n'
}

read_ec_byte_dec() {
  dd if="$EC_IO" bs=1 count=1 skip="$1" 2> /dev/null | od -An -tu1 | tr -d ' \n'
}

write_ec_byte() {
  printf '%b' "\\x$2" \
    | dd of="$EC_IO" bs=1 count=1 seek="$1" conv=notrunc status=none 2> /dev/null
}

tach_to_rpm() {
  local t=$((16#$1))
  [ "$t" -eq 0 ] && echo "0" || echo $(( (0x3C000 + t / 2) / t ))
}

read_cpu_temp() {
  write_ec_byte $EC_CRZN_OFF "01"
  sleep 0.05
  read_ec_byte_dec $EC_TEMP_OFF
}

probe_header() {
  printf "%-8s  %-5s  %-7s  %-6s  %-7s  %-6s\n" \
    "AFAN" "TempC" "CPU RPM" "FTGC" "GPU RPM" "FT2C"
  printf "%-8s  %-5s  %-7s  %-6s  %-7s  %-6s\n" \
    "------" "-----" "-------" "------" "-------" "------"
}

probe_row() {
  local afan=$1 temp frdc fr2c ftgc ft2c rpm1 rpm2
  temp=$(read_cpu_temp)
  frdc=$(read_ec_byte $EC_FRDC_OFF)
  fr2c=$(read_ec_byte $EC_FR2C_OFF)
  ftgc=$(read_ec_byte $EC_FTGC_OFF)
  ft2c=$(read_ec_byte $EC_FT2C_OFF)
  rpm1=$(tach_to_rpm "$frdc")
  rpm2=$(tach_to_rpm "$fr2c")
  printf "0x%-6s  %-5s  %-7s  0x%-4s  %-7s  0x%-4s" \
    "$afan" "$temp" "$rpm1" "$ftgc" "$rpm2" "$ft2c"
  if [ "$rpm1" -le 964 ] && [ "$rpm2" -le 964 ]; then
    printf "  ** BOTH MIN **"
  elif [ "$rpm1" -le 964 ] || [ "$rpm2" -le 964 ]; then
    printf "  * one min *"
  fi
  printf "\n"
}

# Sweep AFAN values high→low (passive first so system stays cool).
# Usage: cmd_probe [--all | LO HI]
cmd_probe() {
  need_root
  ensure_ec_sys || return 1

  local lo=0 hi=0x88 settle=4
  if [[ "${1:-}" == "--all" ]]; then
    hi=0xff
  elif [ -n "${1:-}" ] && [ -n "${2:-}" ]; then
    lo=$((16#$1))
    hi=$((16#$2))
    [ "$lo" -le "$hi" ] || { echo "LO must be <= HI" >&2; return 2; }
  fi

  local orig=$(read_afan)
  echo "Original AFAN=0x$orig  CPU temp=$(read_cpu_temp)C"
  echo "Sweeping 0x$(printf '%02x' "$hi") -> 0x$(printf '%02x' "$lo") (passive first, ${settle}s settle)"
  echo ""
  probe_header

  local cleanup_afan=$orig
  trap 'echo ""; echo "Restoring AFAN=0x$cleanup_afan ..."; write_ec_byte $EC_AFAN_OFFSET "$cleanup_afan"; echo "Done."; trap - EXIT' EXIT

  local i v rb
  for (( i=hi; i>=lo; i-- )); do
    v=$(printf '%02x' "$i")
    write_ec_byte $EC_AFAN_OFFSET "$v"
    rb=$(read_ec_byte $EC_AFAN_OFFSET)
    if [ "$rb" != "$v" ]; then
      printf "0x%-6s  *** EC rejected (reads 0x%s) ***\n" "$v" "$rb"
      continue
    fi
    sleep "$settle"
    probe_row "$v"
  done
}

# Live-monitor fans at a given AFAN value. Ctrl-C to stop.
# Usage: cmd_monitor [hex]
cmd_monitor() {
  need_root
  ensure_ec_sys || return 1

  local hex
  hex=$(parse_hex2 "${1:-88}") || return $?

  local orig=$(read_afan)
  trap 'echo ""; echo "Restoring AFAN=0x$orig ..."; write_ec_byte $EC_AFAN_OFFSET "$orig"; echo "Done."; trap - EXIT' EXIT

  write_ec_byte $EC_AFAN_OFFSET "$hex"
  echo "Monitoring AFAN=0x$hex (was 0x$orig).  Ctrl-C to stop."
  echo ""
  probe_header
  while true; do
    probe_row "$(read_ec_byte $EC_AFAN_OFFSET)"
    sleep 2
  done
}

cmd_help() {
  cat << 'EOF'
usage: hp-power {status|turbo|balanced|silent|afan|hwp|probe|monitor|help}

Manual override. No daemons, no auto. What you set stays set until next call or reboot.

  status                  current state
  turbo      [sudo]       PL=37/95W perf perf perf  AFAN=0x00 HWP=0x37 (~5.5GHz)
  balanced   [sudo]       PL=28/55W perf perf bal   AFAN=0x44 HWP=0x1a (~2.6GHz)
  silent     [sudo]       PL=15/25W save power cool AFAN=0x88 HWP=0x13 (~1.9GHz)
  afan [hex] [sudo]       read or write EC byte 0x2D
  hwp  [hex] [sudo]       read or write MSR 0x774 max_perf. valid: 01 13 1a 26 30 37
  probe      [sudo]       sweep AFAN 0x88->0x00 showing fan RPM + temps
  probe --all             sweep full range 0xff->0x00
  probe LO HI             sweep hex range (e.g. probe 70 90)
  monitor [hex] [sudo]    live-watch fans at AFAN=hex (default 0x88). Ctrl-C to stop
  help                    this

AFAN values (EC offset 0x2D, from DSDT + probing):
  0x00       max cooling, both fans ~3400/4000 RPM
  0x08/18/28 both fans off at ≤37C (non-DSDT but stable)
  0x33       both fans briefly off then GPU returns (unstable)
  0x44       moderate, both fans ~3200 RPM
  0x77       CPU ~2961, GPU off
  0x88       most passive; both fans off at ≤35C (CPU fan returns above ~37C)
  0x90+      wraps to aggressive modes (louder, not quieter)

Persistence:
  AFAN  survives reboot, dies on EC reset (battery disconnect / deep S5).
  RAPL/governor/EPP/HWP  reset on reboot, sometimes on S3 resume.
  TLP may stomp governor/EPP on AC plug events; just re-run.

Bypass allowlists: HP_POWER_AFAN_ALLOW_ANY=1 / HP_POWER_HWP_ALLOW_ANY=1
EOF
}

case "${1:-status}" in
  status) cmd_status ;;
  turbo | t) cmd_turbo ;;
  balanced | b) cmd_balanced ;;
  silent | s | battery | bat) cmd_silent ;;
  afan)
    shift
    cmd_afan "$@"
    ;;
  hwp)
    shift
    cmd_hwp "$@"
    ;;
  probe | p)
    shift
    cmd_probe "$@"
    ;;
  monitor | m)
    shift
    cmd_monitor "$@"
    ;;
  help | -h | --help) cmd_help ;;
  *)
    echo "unknown subcommand: ${1:-}" >&2
    cmd_help >&2
    exit 2
    ;;
esac
