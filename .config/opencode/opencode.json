{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow",
      "~/Desktop/**": "allow"
    }
  },
  "autoupdate": false,
  "lsp": false,
  "formatter": false,
  "plugin": [
    "opencode-claude-auth@latest",
    "opencode-gemini-auth@latest",
    "@mohak34/opencode-notifier@latest"
  ]
}
