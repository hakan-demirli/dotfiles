{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow",
      "~/Desktop/**": "allow"
    }
  },
  "theme": "system",
  "autoupdate": false,
  "lsp": false,
  "formatter": false,
  "plugin": [
    "opencode-antigravity-auth@latest",
    "@mohak34/opencode-notifier@latest",
    "@ex-machina/opencode-anthropic-auth"
  ]
}
