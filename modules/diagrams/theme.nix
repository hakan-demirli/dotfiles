{
  fontFamily = "DejaVu Sans, Helvetica, Arial, sans-serif";
  fontFamilyGraphviz = "DejaVu Sans";

  fontSize = {
    title = 18;
    subtitle = 14;
    label = 11;
    body = 10;
    edge = 9;
    small = 8;
    tiny = 7;
  };

  stroke = {
    thin = 0.06;
    medium = 0.10;
    thick = 0.16;
    heavy = 0.20;
  };

  strokeWidthPt = {
    hairline = 0.3;
    thin = 0.5;
    normal = 1.0;
    medium = 1.2;
    thick = 1.5;
  };

  radius = {
    small = 0.10;
    medium = 0.18;
    large = 0.45;
  };

  palette = {
    background = "#ffffff";
    text = "#111827";
    textMuted = "#374151";
    textFaint = "#475569";

    switch = "#dbeafe";
    host = "#dcfce7";
    hostPlanned = "#fef9c3";
    hostRetired = "#fecaca";
    network = "#fef3c7";
    user = "#fce7f3";
    team = "#f3e8ff";
    cluster = "#e2e8f0";
    site = "#ffedd5";
    rack = "#f3f4f6";
    external = "#ffffff";

    edgeUplink = "#1d4ed8";
    edgeDownlink = "#15803d";
    edgeMlag = "#b91c1c";
    edgeMgmt = "#6b21a8";
    edgeDefault = "#374151";

    panelBg = "#f8fafc";
    panelBorder = "#cbd5e1";

    submitBg = "#bfdbfe";
    submitBorder = "#1d4ed8";
    controllerBg = "#fed7aa";
    controllerBorder = "#c2410c";
    partitionBg = "#fef08a";
    partitionBorder = "#a16207";
    computeBg = "#bbf7d0";
    computeBorder = "#15803d";

    danger = "#dc2626";
    dangerBg = "#fecaca";

    gridLine = "#e2e8f0";
    legendBorder = "#94a3b8";
  };

  fleetPalette = [
    {
      fill = "#bfdbfe";
      border = "#1d4ed8";
    }
    {
      fill = "#bbf7d0";
      border = "#15803d";
    }
    {
      fill = "#fed7aa";
      border = "#c2410c";
    }
    {
      fill = "#ddd6fe";
      border = "#6d28d9";
    }
    {
      fill = "#fef08a";
      border = "#a16207";
    }
    {
      fill = "#fbcfe8";
      border = "#be185d";
    }
    {
      fill = "#a7f3d0";
      border = "#047857";
    }
    {
      fill = "#fda4af";
      border = "#be123c";
    }
  ];

  fleetSolo = {
    fill = "#f1f5f9";
    border = "#94a3b8";
  };
}
